{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(sage *)",
      "Bash(pdflatex *)",
      "Bash(bibtex *)",
      "Bash(latexmk *)",
      "Bash(pip3 list*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git show*)",
      "Bash(ls *)",
      "Bash(make *)",
      "Bash(cmake *)",
      "Bash(gcc *)",
      "Bash(clang *)",
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push*)",
      "Bash(git checkout -- *)",
      "Bash(git reset --hard*)",
      "Read(.env*)",
      "Read(*/secrets/*)"
    ]
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude is waiting for input\" with title \"Claude Code\" sound name \"Tink\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task complete\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true
  },
  "autoMemoryEnabled": false
}
